# =============================================================================
# Backchannel — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: Service credentials (Notion token, Telegram API keys, etc.) are
# configured via the Web UI and stored in the database. This file is only
# for general application settings.

# --- General -----------------------------------------------------------------
DATABASE_PATH=data/backchannel.db
# Optional: omit DASHBOARD_PORT and WEB_DEV_PORT to pick stable ports from this
# project's folder path (different checkouts avoid clashing with each other).
# DASHBOARD_PORT=8787
# WEB_DEV_PORT=5173
USER_EMAIL=you@example.com

# --- Automation (OpenClaw / HTTP) -------------------------------------------
# Optional. When set, enables POST /api/context/build with header:
#   Authorization: Bearer <READ_API_KEY>
# Use a long random secret; the endpoint returns retrieval markdown for external LLMs.
# READ_API_KEY=
