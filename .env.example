# =============================================================================
# Backchannel — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- General -----------------------------------------------------------------
DATABASE_PATH=data/backchannel.db
DASHBOARD_PORT=8787
USER_EMAIL=you@example.com

# --- Notion ------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gmail -------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=data/tokens/credentials.json
GMAIL_TOKEN_PATH=data/tokens/token.json

# --- Telegram ----------------------------------------------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_PATH=data/sessions/backchannel.session

# --- ProtonMail --------------------------------------------------------------
PROTONMAIL_BRIDGE_HOST=127.0.0.1
PROTONMAIL_BRIDGE_PORT=1143
PROTONMAIL_BRIDGE_EMAIL=your-bridge-email@protonmail.ch
PROTONMAIL_BRIDGE_PASSWORD=your-bridge-password

# --- WhatsApp ----------------------------------------------------------------
WHATSAPP_BRIDGE_BINARY=whatsapp-bridge/whatsapp-bridge
WHATSAPP_BRIDGE_DB=whatsapp-bridge/store/messages.db
